---
import Layout from "../layouts/Layout.astro";
import ProjectCarousel from "../components/ProjectCarousel.astro";
import { WHATSAPP_LINK } from "../consts/site";

import ER1 from "../assets/Essence_R/ER1.jpeg";
import ER2 from "../assets/Essence_R/ER2.jpeg";
import ER3 from "../assets/Essence_R/ER3.jpeg";
import ER4 from "../assets/Essence_R/ER4.jpeg";
import ER5 from "../assets/Essence_R/ER5.jpeg";
import ER6 from "../assets/Essence_R/ER6.jpeg";

import AptoCC_1 from "../assets/AptoCC/AptoCC_1.jpeg";
import AptoCC_2 from "../assets/AptoCC/AptoCC_2.jpeg";
import AptoCC_3 from "../assets/AptoCC/AptoCC_3.jpeg";
import AptoCC_4 from "../assets/AptoCC/AptoCC_4.jpeg";
import AptoCC_5 from "../assets/AptoCC/AptoCC_5.jpeg";
import AptoCC_6 from "../assets/AptoCC/AptoCC_6.jpeg";
import AptoCC_7 from "../assets/AptoCC/AptoCC_7.jpeg";
import AptoCC_8 from "../assets/AptoCC/AptoCC_8.jpeg";

import AptoLR1 from "../assets/AptoLR/AptoLR1.jpg";
import AptoLR2 from "../assets/AptoLR/AptoLR2.jpg";
import AptoLR3 from "../assets/AptoLR/AptoLR3.jpg";
import AptoLR4 from "../assets/AptoLR/AptoLR4.jpg";
import AptoLR5 from "../assets/AptoLR/AptoLR5.jpg";
import AptoLR6 from "../assets/AptoLR/AptoLR6.jpg";

import CasaM8_1 from "../assets/CasaM8/CasaM8_1.jpeg";
import CasaM8_2 from "../assets/CasaM8/CasaM8_2.jpeg";

import CAMSVC1 from "../assets/CAMSanVicenteDeChucuri/CAMSVC1.png";
import CAMSVC2 from "../assets/CAMSanVicenteDeChucuri/CAMSVC2.png";
import CAMSVC3 from "../assets/CAMSanVicenteDeChucuri/CAMSVC3.png";
import CAMSVC4 from "../assets/CAMSanVicenteDeChucuri/CAMSVC4.png";
import CAMSVC5 from "../assets/CAMSanVicenteDeChucuri/CAMSVC5.png";
import CAMSVC6 from "../assets/CAMSanVicenteDeChucuri/CAMSVC6.png";
import CAMSVC7 from "../assets/CAMSanVicenteDeChucuri/CAMSVC7.png";

const featuredProjects = [
    {
        id: "aptolr",
        title: "APARTAMENTO LR",
        images: [
            AptoLR1.src,
            AptoLR2.src,
            AptoLR3.src,
            AptoLR4.src,
            AptoLR5.src,
            AptoLR6.src,
        ],
        span: "lg:col-span-7",
    },
    {
        id: "aptocc",
        title: "APARTAMENTO CC",
        images: [
            AptoCC_1.src,
            AptoCC_2.src,
            AptoCC_3.src,
            AptoCC_4.src,
            AptoCC_5.src,
            AptoCC_6.src,
            AptoCC_7.src,
            AptoCC_8.src,
        ],
        span: "lg:col-span-4 lg:col-start-9 md:mt-36",
    },
    {
        id: "CAMSVC",
        title: "CAM SAN VICENTE CHUCURI",
        images: [
            CAMSVC1.src,
            CAMSVC2.src,
            CAMSVC3.src,
            CAMSVC4.src,
            CAMSVC5.src,
            CAMSVC6.src,
            CAMSVC7.src,
        ],
        span: "lg:col-span-5 md:mt-[-4rem]",
    },
    {
        id: "essence-r",
        title: "ESSENCE R",
        images: [ER1.src, ER2.src, ER3.src, ER4.src, ER5.src, ER6.src],
        span: "lg:col-span-6 lg:col-start-7",
    },
];
---

<Layout title="Minimal arquitectura | Inicio">
    <header
        class="relative mt-40 h-[calc(100vh-10rem)] min-h-[680px] w-full overflow-hidden bg-black md:mt-32 md:h-[calc(100vh-8rem)] md:min-h-[600px]"
    >
        <div class="absolute inset-0 z-0">
            <ProjectCarousel
                images={[
                    CasaM8_1.src,
                    AptoCC_1.src,
                    ER1.src,
                    AptoLR1.src,
                    CasaM8_2.src,
                    AptoCC_2.src,
                    ER2.src,
                    AptoLR2.src,
                    AptoCC_3.src,
                    ER3.src,
                    AptoLR3.src,
                    CAMSVC2.src,
                    AptoCC_4.src,
                    CAMSVC3.src,
                    ER4.src,
                    AptoLR4.src,
                    CAMSVC1.src,
                ]}
                id="hero-carousel"
                columns={1}
            />
        </div>

        <div
            class="absolute inset-0 z-10 bg-linear-to-t from-stone-950 via-stone-950/25 to-transparent pointer-events-none"
        >
        </div>

        <div
            class="pointer-events-none relative z-20 mx-auto flex h-full max-w-[1920px] flex-col justify-end px-6 pb-16 sm:px-8 sm:pb-20 md:pb-24 lg:pl-28"
        >
            <p
                class="mb-6 font-label text-[0.8rem] uppercase tracking-[0.45em] text-white/75 sm:mb-8"
            >
                Minimal arquitectura
            </p>
            <h1
                class="max-w-[1200px] font-headline text-[clamp(4.4rem,16vw,10rem)] leading-[0.88] tracking-tighter text-white uppercase drop-shadow-xl md:leading-[0.85]"
            >
                Definiendo
                <span class="block">el vacio.</span>
            </h1>
            <p
                class="mt-6 max-w-4xl font-body text-lg leading-relaxed text-white/85 sm:text-2xl"
            >
                Espacios honestos, funcionales y pulidos con una presencia
                consistente desde movil hasta escritorio.
            </p>
            <div class="mt-10">
                <a
                    href={WHATSAPP_LINK}
                    class="pointer-events-auto inline-flex items-center justify-center bg-white px-10 py-5 font-label text-[0.8rem] uppercase tracking-[0.35em] text-black transition-colors duration-300 hover:bg-stone-200"
                >
                    Contáctanos
                </a>
            </div>
        </div>
    </header>

    <section class="pb-40 px-8 max-w-[1920px] mx-auto">
        <div
            class="flex flex-col md:flex-row justify-between items-start md:items-end mb-20 gap-8"
        >
            <div>
                <h3
                    class="font-headline text-5xl font-bold tracking-tighter uppercase mt-6"
                >
                    Proyectos
                </h3>
            </div>
            <a
                href="/proyectos"
                class="font-label text-[0.8rem] uppercase tracking-widest border-b border-primary pb-2 hover:pr-6 transition-all duration-300 flex items-center group"
            >
                Ver mas proyectos
                <span
                    class="material-symbols-outlined ml-2 group-hover:rotate-45 transition-transform"
                >
                    north_east
                </span>
            </a>
        </div>
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-y-16 md:gap-x-6 lg:gap-x-8 items-start"
        >
            {
                featuredProjects.map((project) => (
                    <div class={`${project.span} group block`}>
                        <div class="relative overflow-hidden bg-surface-container-high aspect-16/10 md:aspect-auto md:h-[600px]">
                            <ProjectCarousel
                                images={project.images}
                                id={project.id}
                                columns={1}
                            />
                        </div>
                        <div class="mt-8 flex justify-between items-start">
                            <div>
                                <h4 class="font-headline text-2xl font-bold mb-2 group-hover:text-primary/70 transition-colors">
                                    {project.title}
                                </h4>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
        <div class="mt-32 flex justify-center">
            <a
                href={WHATSAPP_LINK}
                class="bg-primary text-on-primary px-12 py-5 font-label uppercase tracking-[0.2em] text-[0.8rem] hover:opacity-90 transition-opacity active:scale-95 duration-200"
            >
                Cotizar proyecto
            </a>
        </div>
    </section>
</Layout>
