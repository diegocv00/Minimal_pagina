---

<Layout title="Minimal arquitectura | Inicio">
    <!-- Hero Section -->
    <header class="relative h-screen w-full overflow-hidden bg-black">
        <div class="absolute inset-0 z-0">
            <ProjectCarousel
                images={featuredProjects.map((p) => p.images[0])}
                id="hero-carousel"
                columns={1}
            />
        </div>
        <div
            class="absolute inset-0 z-10 bg-linear-to-t from-stone-950 via-stone-950/20 to-transparent pointer-events-none"
        >
        </div>
        <div
            class="relative z-20 h-full flex flex-col justify-end px-8 pb-24 max-w-[1920px] mx-auto pointer-events-none"
        >
            <h1
                class="font-headline text-5xl sm:text-[5rem] md:text-[8rem] lg:text-[10rem] leading-[0.9] md:leading-[0.85] tracking-tighter text-white max-w-5xl uppercase drop-shadow-xl"
            >
                Definiendo<br />el vacío.
            </h1>
        </div>
    </header>
    <!-- Featured Projects Grid (Intentional Asymmetry) -->
    <section class="pb-40 px-8 max-w-[1920px] mx-auto">
        <div
            class="flex flex-col md:flex-row justify-between items-start md:items-end mb-20 gap-8"
        >
            <div>
                <h3
                    class="font-headline text-5xl font-bold tracking-tighter uppercase mt-6"
                >
                    Proyectos
                </h3>
            </div>
            <a
                href="/proyectos"
                class="font-label text-[0.8rem] uppercase tracking-widest border-b border-primary pb-2 hover:pr-6 transition-all duration-300 flex items-center group"
            >
                Ver más proyectos <span
                    class="material-symbols-outlined ml-2 group-hover:rotate-45 transition-transform"
                    >north_east</span
                >
            </a>
        </div>
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-y-16 md:gap-x-6 lg:gap-x-8 items-start"
        >
            {
                featuredProjects.map((project) => (
                    <div class={`${project.span} group block`}>
                        <div class="relative overflow-hidden bg-surface-container-high aspect-16/10 md:aspect-auto md:h-[600px]">
                            <ProjectCarousel
                                images={project.images}
                                id={project.id}
                                columns={1}
                            />
                        </div>
                        <div class="mt-8 flex justify-between items-start">
                            <div>
                                <h4 class="font-headline text-2xl font-bold mb-2 group-hover:text-primary/70 transition-colors">
                                    {project.title}
                                </h4>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
        <div class="mt-32 flex justify-center">
            <a
                href="https://wa.me/573008299673"
                class="bg-primary text-on-primary px-12 py-5 font-label uppercase tracking-[0.2em] text-[0.8rem] hover:opacity-90 transition-opacity active:scale-95 duration-200"
            >
                Cotizar Proyecto
            </a>
        </div>
    </section>
</Layout>
