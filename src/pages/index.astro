---
import Layout from "../layouts/Layout.astro";
import ProjectCarousel from "../components/ProjectCarousel.astro";
import { WHATSAPP_DISPLAY, WHATSAPP_LINK } from "../consts/site";

import ER1 from "../assets/Essence_R/ER1.jpeg";
import ER2 from "../assets/Essence_R/ER2.jpeg";
import ER3 from "../assets/Essence_R/ER3.jpeg";
import ER4 from "../assets/Essence_R/ER4.jpeg";
import ER5 from "../assets/Essence_R/ER5.jpeg";
import ER6 from "../assets/Essence_R/ER6.jpeg";

import AptoCC_1 from "../assets/AptoCC/AptoCC_1.jpeg";
import AptoCC_2 from "../assets/AptoCC/AptoCC_2.jpeg";
import AptoCC_3 from "../assets/AptoCC/AptoCC_3.jpeg";
import AptoCC_4 from "../assets/AptoCC/AptoCC_4.jpeg";
import AptoCC_5 from "../assets/AptoCC/AptoCC_5.jpeg";
import AptoCC_6 from "../assets/AptoCC/AptoCC_6.jpeg";
import AptoCC_7 from "../assets/AptoCC/AptoCC_7.jpeg";
import AptoCC_8 from "../assets/AptoCC/AptoCC_8.jpeg";

import AptoLR1 from "../assets/AptoLR/AptoLR1.jpg";
import AptoLR2 from "../assets/AptoLR/AptoLR2.jpg";
import AptoLR3 from "../assets/AptoLR/AptoLR3.jpg";
import AptoLR4 from "../assets/AptoLR/AptoLR4.jpg";
import AptoLR5 from "../assets/AptoLR/AptoLR5.jpg";
import AptoLR6 from "../assets/AptoLR/AptoLR6.jpg";

import CasaM8_1 from "../assets/CasaM8/CasaM8_1.jpeg";
import CasaM8_2 from "../assets/CasaM8/CasaM8_2.jpeg";

const featuredProjects = [
    {
        id: "aptolr",
        title: "APARTAMENTO LR",
        images: [
            AptoLR1.src,
            AptoLR2.src,
            AptoLR3.src,
            AptoLR4.src,
            AptoLR5.src,
            AptoLR6.src,
        ],
        span: "lg:col-span-7",
    },
    {
        id: "aptocc",
        title: "APARTAMENTO CC",
        images: [
            AptoCC_1.src,
            AptoCC_2.src,
            AptoCC_3.src,
            AptoCC_4.src,
            AptoCC_5.src,
            AptoCC_6.src,
            AptoCC_7.src,
            AptoCC_8.src,
        ],
        span: "lg:col-span-4 lg:col-start-9 md:mt-24",
    },
    {
        id: "brutalist-pavilion",
        title: "THE BRUTALIST PAVILION",
        images: [
            "https://lh3.googleusercontent.com/aida-public/AB6AXuD4JXV12e-o0YkLfnAT8tTnDlyyOJP5NI1r6vA97mmDXyb6G1xRNfFmN3xnrIq6tpCdDOxwOz8UfLZAJLjMMsMW_FfDpiHc1wpo1yYG2FM7I8LnO7aUXkxsTWHu0p5UbowiVm3rQnQpJmftHnKnAN1LjKDNTZo3B5FG8SCNsUCkIggpbhYGIaked7DhAf2Xkbwcki_EuGqYU6BmajIndLfeA1ZJU2lj9-u8IaHCcaOJZzkHmTNtjf910m8ptGCf_W9SS4Cgy8KjTSCT",
            "https://lh3.googleusercontent.com/aida-public/AB6AXuBEijYhtNeNQzeV-Dml6bGm_LulqViqceIS69AWqsjnV5OD2Dw_ifXmy-rGk7WMolB05XOSMHTZymou929_OZ5NEwc_gH1fzodia2t45Oe18m-g8WoCC_A_3d0abdtzgAmwepbHf858j1qQBXVF-ZsNMhoqXyW-yvHqGi0zxeCcvgfzQg3ZKoQNyszYONFg3r_5w06yskRZ3l0U2jogXfItS_ohE5TpmCWB7ZluN1iZVV0hI9s_LztY_rJZB5lWlZz7HdEzsM-Us5IM",
        ],
        span: "lg:col-span-5 lg:-mt-12",
    },
    {
        id: "essence-r",
        title: "ESSENCE R",
        images: [ER1.src, ER2.src, ER3.src, ER4.src, ER5.src, ER6.src],
        span: "lg:col-span-6 lg:col-start-7",
    },
];
---

<Layout title="Minimal arquitectura | Inicio">
    <header
        class="relative isolate overflow-hidden bg-primary text-white"
        style="margin-top: var(--header-offset); min-height: calc(100svh - var(--header-offset));"
    >
        <div class="absolute inset-0 z-0">
            <ProjectCarousel
                images={[
                    CasaM8_1.src,
                    AptoCC_1.src,
                    ER1.src,
                    AptoLR1.src,
                    CasaM8_2.src,
                    AptoCC_2.src,
                    ER2.src,
                    AptoLR2.src,
                    AptoCC_3.src,
                    ER3.src,
                    AptoLR3.src,
                    AptoCC_4.src,
                    ER4.src,
                    AptoLR4.src,
                ]}
                id="hero-carousel"
                columns={1}
            />
        </div>

        <div
            class="absolute inset-0 z-10 bg-linear-to-br from-primary via-primary/60 to-primary/20 pointer-events-none"
        >
        </div>

        <div
            class="site-container relative z-20 flex min-h-[calc(100svh-var(--header-offset))] flex-col justify-end py-16 sm:py-20 lg:py-24"
        >
            <div class="max-w-4xl">
                <p
                    class="font-label text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-white/68"
                >
                    Minimal Arquitectura
                </p>
                <h1
                    class="mt-6 font-headline text-[clamp(3.4rem,10vw,8rem)] leading-[0.9] tracking-[-0.05em] uppercase drop-shadow-xl"
                >
                    Definiendo<span class="block">el vacio.</span>
                </h1>
                <p
                    class="mt-6 max-w-2xl text-base leading-relaxed text-white/76 sm:text-lg"
                >
                    Espacios honestos, funcionales y pulidos con una presencia
                    consistente desde movil hasta escritorio.
                </p>
                <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                    <a
                        href={WHATSAPP_LINK}
                        class="inline-flex items-center justify-center border border-white bg-white px-6 py-3 text-center font-label text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-primary transition-colors duration-300 hover:bg-surface-container-lowest"
                    >
                        Cotizar proyecto
                    </a>
                    <a
                        href={WHATSAPP_LINK}
                        class="button-secondary sm:min-w-[15rem]"
                    >
                        {WHATSAPP_DISPLAY}
                    </a>
                </div>
            </div>
        </div>
    </header>

    <section class="site-container section-space">
        <div
            class="mb-14 flex flex-col gap-6 md:mb-16 md:flex-row md:items-end md:justify-between"
        >
            <div>
                <h2
                    class="mt-2 font-headline text-4xl font-bold uppercase tracking-tight sm:text-5xl"
                >
                    Proyectos
                </h2>
            </div>
            <a
                href="/proyectos"
                class="inline-flex items-center gap-2 border-b border-primary pb-2 font-label text-[0.72rem] font-semibold uppercase tracking-[0.24em] transition-all duration-300 hover:gap-4"
            >
                Ver mas proyectos
                <span class="material-symbols-outlined">north_east</span>
            </a>
        </div>

        <div
            class="grid grid-cols-1 items-start gap-y-12 md:grid-cols-2 md:gap-x-6 lg:grid-cols-12 lg:gap-x-8"
        >
            {
                featuredProjects.map((project) => (
                    <div class={`${project.span} group block`}>
                        <div class="relative aspect-[4/5] overflow-hidden bg-surface-container-high sm:aspect-[16/11] md:h-[420px] md:aspect-auto lg:h-[520px]">
                            <ProjectCarousel
                                images={project.images}
                                id={project.id}
                                columns={1}
                            />
                        </div>
                        <div class="mt-6">
                            <h3 class="font-headline text-2xl font-bold transition-colors group-hover:text-primary/70">
                                {project.title}
                            </h3>
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="mt-12 flex justify-center sm:mt-16">
            <a href={WHATSAPP_LINK} class="button-primary">Cotizar proyecto</a>
        </div>
    </section>
</Layout>
