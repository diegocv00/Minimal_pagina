---
import Layout from "../layouts/Layout.astro";
import fondoBanner from "../assets/fondoBanner.png";
---

<Layout title="Minimal arquitectura | Nosotros">
    <main class="pt-32">
        <!-- Hero Section -->
        <section class="px-8 max-w-[1920px] mx-auto mb-40">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
                <div class="lg:col-span-7">
                    <h1
                        class="text-4xl sm:text-[3rem] md:text-[3.5rem] leading-[1.1] font-bold tracking-tight text-primary mb-8 max-w-2xl font-headline"
                    >
                        Esculpiendo el vacío, definiendo la permanencia.
                    </h1>
                    <p
                        class="font-body text-on-surface-variant text-lg max-w-xl leading-relaxed"
                    >
                        Arquitectura de honestidad material y claridad
                        estructural desde 2019.
                    </p>
                </div>
                <div class="lg:col-span-5 relative">
                    <img
                        class="w-full aspect-[4/5] object-cover"
                        data-alt="Monolithic concrete building with sharp geometric lines and deep shadows against a clear sky"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAaWEGi6GzES3FLZDMth2WDPopEXJ3zI8wmXOj4uuFlgrxqABH2YEQzMAMSkmGK_qUAOdaSDXUf7-iTMbyR5XHvMtzK2Y6ZSueuwit_5yw_80rjIxZntlB06CBZuGYozmQ2EoHVRfVBV1QhOUonK_P4wAKhvkZ9xrmXwKCoJN3OAEsMg2s3MmikNeNcjGQUERL79sVjc14UsQQLrDWjyJeriRbo4GgVVFiwuDMnqTJbelMfh-pEE-ZJvmMHXxA-5qQ8GMan0lSc17Mt"
                        alt="Monolithic concrete building"
                    />
                    <div
                        class="absolute -bottom-12 -left-12 hidden xl:block w-48 h-48 bg-surface-container-highest"
                    >
                    </div>
                </div>
            </div>
        </section>

        <!-- Our Philosophy Section -->
        <section class="bg-surface-container-low py-40">
            <div class="px-8 max-w-[1920px] mx-auto">
                <div class="flex flex-col md:flex-row gap-20">
                    <div class="md:w-1/3">
                        <span
                            class="font-label uppercase tracking-[0.2em] text-[0.75rem] text-outline font-bold"
                            >Nuestra filosofía</span
                        >
                        <h2
                            class="font-headline text-[2rem] sm:text-4xl font-bold mt-4 leading-tight"
                        >
                            La arquitectura como un acto de silencio.
                        </h2>
                    </div>
                    <div
                        class="md:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-16"
                    >
                        <div>
                            <h3 class="font-headline text-xl font-bold mb-4">
                                Materialidad radical
                            </h3>
                            <p class="text-on-surface-variant leading-relaxed">
                                Expresión pura de hormigón, acero y vidrio en
                                diálogo con la luz.
                            </p>
                        </div>
                        <div>
                            <h3 class="font-headline text-xl font-bold mb-4">
                                Sostenibilidad estructural
                            </h3>
                            <p class="text-on-surface-variant leading-relaxed">
                                Diseños enfocados en durabilidad e
                                integración climática.
                            </p>
                        </div>

                    </div>
                </div>
            </div>
        </section>

        <!-- The Team Section -->
        <section class="py-40 px-8 max-w-[1920px] mx-auto">
            <div class="mb-24 flex justify-between items-end">
                <h2
                    class="font-headline text-4xl sm:text-[3rem] font-bold tracking-tight"
                >
                    El equipo
                </h2>
                <span
                    class="font-label uppercase tracking-[0.2em] text-[0.75rem] text-outline mb-4"
                    >Mentes Creativas</span
                >
            </div>
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-24 gap-x-12"
            >
                <!-- Member 1 -->
                <div class="group">
                    <div class="bg-surface-container-high mb-8 overflow-hidden">
                        <img
                            class="w-full aspect-[3/4] object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105"
                            data-alt=""
                            src=""
                            alt=""
                        />
                    </div>
                    <div class="flex justify-between items-start">
                        <div>
                            <h4 class="font-headline text-xl font-bold"></h4>
                            <p
                                class="font-label uppercase tracking-widest text-[0.65rem] text-outline mt-1"
                            ></p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Quote Section -->
        <section class="py-40 bg-primary text-on-primary">
            <div class="px-8 max-w-[1920px] mx-auto text-center">
                <p
                    class="font-headline text-[2rem] sm:text-[3rem] md:text-[4rem] leading-none font-extralight tracking-tighter italic"
                >
                    "La arquitectura es la voluntad de una época traducida a
                    espacio."
                </p>
                <p
                    class="font-label uppercase tracking-[0.4em] text-[0.75rem] mt-12 opacity-60"
                >
                    Mies van der Rohe
                </p>
            </div>
        </section>

        <!-- Stats Bento Grid -->
        <section class="py-40 px-8 max-w-[1920px] mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                <div
                    class="bg-surface-container p-12 flex flex-col justify-between aspect-square md:col-span-2 lg:col-span-1 border border-outline-variant/30"
                >
                    <span class="font-headline text-6xl font-bold">7</span>
                    <p
                        class="font-label uppercase tracking-widest text-outline text-sm"
                    >
                        Años de trayectoria
                    </p>
                </div>
                <div
                    class="bg-surface-container-lowest p-12 flex flex-col justify-between aspect-square border border-outline-variant/30"
                >
                    <span class="font-headline text-6xl font-bold">+30</span>
                    <p
                        class="font-label uppercase tracking-widest text-outline text-sm"
                    >
                        Proyectos completados
                    </p>
                </div>
                <div
                    class="bg-primary text-on-primary p-12 flex flex-col justify-between aspect-square md:col-span-2 lg:col-span-1"
                >
                    <span class="font-headline text-6xl font-bold">+17000</span>
                    <p
                        class="font-label uppercase tracking-widest text-on-primary opacity-60 text-sm"
                    >
                        Metros cuadrados diseñados
                    </p>
                </div>
            </div>
        </section>

        <!-- Call to Action -->
        <section
            class="relative py-40 bg-stone-950 text-white text-center px-8 bg-cover bg-center"
            style={`background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(${fondoBanner.src});`}
        >
            <div class="relative z-10">
                <h4
                    class="font-headline text-[2rem] sm:text-[3rem] font-bold mb-12 uppercase tracking-tighter italic"
                >
                    ¿Tienes un proyecto en mente?
                </h4>
                <a
                    class="px-12 py-6 bg-white text-black font-label text-[0.8rem] font-bold uppercase tracking-[0.2em] transition-all hover:bg-stone-200"
                    href="https://wa.me/573008299673">Cotiza ahora</a
                >
            </div>
        </section>
    </main>
</Layout>
