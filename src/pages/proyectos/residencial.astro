---
import Layout from '../../layouts/Layout.astro';
import ProjectCarousel from '../../components/ProjectCarousel.astro';
import fondoBanner from '../../assets/fondoBanner.png';

import AptoCC_1 from '../../assets/AptoCC/AptoCC_1.jpeg';
import AptoCC_2 from '../../assets/AptoCC/AptoCC_2.jpeg';
import AptoCC_3 from '../../assets/AptoCC/AptoCC_3.jpeg';
import AptoCC_4 from '../../assets/AptoCC/AptoCC_4.jpeg';
import AptoCC_5 from '../../assets/AptoCC/AptoCC_5.jpeg';
import AptoCC_6 from '../../assets/AptoCC/AptoCC_6.jpeg';
import AptoCC_7 from '../../assets/AptoCC/AptoCC_7.jpeg';
import AptoCC_8 from '../../assets/AptoCC/AptoCC_8.jpeg';

import AptoCV_1 from '../../assets/AptoCV/AptoCV_1.jpeg';
import AptoCV_2 from '../../assets/AptoCV/AptoCV_2.jpeg';
import AptoCV_3 from '../../assets/AptoCV/AptoCV_3.jpeg';
import AptoCV_4 from '../../assets/AptoCV/AptoCV_4.jpeg';
import AptoCV_5 from '../../assets/AptoCV/AptoCV_5.jpeg';
import AptoCV_6 from '../../assets/AptoCV/AptoCV_6.jpeg';
import AptoCV_7 from '../../assets/AptoCV/AptoCV_7.jpeg';
import AptoCV_8 from '../../assets/AptoCV/AptoCV_8.jpeg';
import AptoCV_9 from '../../assets/AptoCV/AptoCV_9.jpeg';
import AptoCV_10 from '../../assets/AptoCV/AptoCV_10.jpeg';
 
import Apto602_1 from '../../assets/Apto602/Apto602_1.jpeg';
import Apto602_2 from '../../assets/Apto602/Apto602_2.jpeg';
import Apto602_3 from '../../assets/Apto602/Apto602_3.jpeg';
import Apto602_4 from '../../assets/Apto602/Apto602_4.jpeg';
import Apto602_5 from '../../assets/Apto602/Apto602_5.jpeg';

interface Project {
    id: string;
    title: string;
    location: string;
    description: string;
    images: string[];
    span: string;
}

const projects: Project[] = [
    {
        id: 'aptocc',
        title: 'APARTAMENTO CC',
        location: '', 
        description: 'Remodelación de un apartmento enfocada en la optimización del espacio y materialidad pura.',
        images: [
            AptoCC_1.src,
            AptoCC_2.src,
            AptoCC_3.src,
            AptoCC_4.src,
            AptoCC_5.src,
            AptoCC_6.src,
            AptoCC_7.src,
            AptoCC_8.src
        ],
        span: 'md:col-span-10 md:col-start-2'
    },

    {
        id: 'aptocv',
        title: 'APARTAMENTO CV301',
        location: '', 
        description: 'Vivienda unifamiliar con énfasis en la conexión interior-exterior y materialidad contemporánea.',
        images: [
            AptoCV_1.src,
            AptoCV_2.src,
            AptoCV_3.src,
            AptoCV_4.src,
            AptoCV_5.src,
            AptoCV_6.src,
            AptoCV_7.src,
            AptoCV_8.src,
            AptoCV_9.src,
            AptoCV_10.src
        ],
        span: 'md:col-span-12'
    },
    {
        id: 'apto602',
        title: 'APARTAMENTO 602',
        location: '', 
        description: 'Vivienda unifamiliar enfocada en la armonía geométrica y materialidad contemporánea.',
        images: [
            Apto602_1.src,
            Apto602_2.src,
            Apto602_3.src,
            Apto602_4.src,
            Apto602_5.src
        ],
        span: 'md:col-span-12'
    }
];
---

<Layout title="Minimal arquitectura | Residencial">
    <main class="pt-32 pb-24">
        <!-- Section Header -->
        <header class="px-8 mb-12">
            <div class="max-w-[1920px] mx-auto flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div>
                    <span class="font-label text-[1rem] uppercase tracking-[0.2em] text-outline mb-4 block"> Sector</span>
                    <h1 class="font-headline text-[2.5rem] sm:text-[3rem] md:text-[3.5rem] leading-none font-extrabold tracking-tighter uppercase text-stone-900">RESIDENCIAL</h1>
                </div>
                <div class="max-w-md">
                    <p class="font-body text-lg text-on-surface-variant leading-relaxed font-light">
                        Una curación de viviendas monolíticas, explorando la intersección entre masa pesada y luz etérea. La arquitectura como contenedor silencioso de vida.
                    </p>
                </div>
            </div>
        </header>

        <!-- Projects: Full-Width Sections -->
        <div>
            {projects.map((project) => (
                <section class="mb-20 md:mb-32 overflow-hidden">
                    <!-- Global Image Block -->
                    <div class="w-full relative bg-stone-100 aspect-video md:aspect-21/9">
                        <ProjectCarousel images={project.images} id={project.id} />
                    </div>
                    
                    <!-- Global Info Block -->
                    <div class="w-full mt-6 md:mt-8 px-8">
                        <div class="grid grid-cols-1 md:grid-cols-12">
                            <div class="md:col-span-12">
                                <h2 class="font-headline text-3xl md:text-4xl font-extrabold uppercase tracking-tighter mb-4 leading-none">
                                    {project.title}
                                </h2>
                                <p class="font-body text-[0.95rem] md:text-lg text-on-surface-variant leading-relaxed opacity-80 max-w-none">
                                    {project.description}
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
            ))}
        </div>



        <!-- CTA Section: Minimalist Intervention -->
        <section class="relative mt-48 px-8 py-32 bg-stone-950 text-white flex items-center justify-center text-center bg-cover bg-center" style={`background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(${fondoBanner.src});`}>
            <div class="relative z-10 max-w-2xl">
                <h3 class="font-headline text-4xl font-extrabold uppercase tracking-tighter mb-8 italic">Empieza tu sueño</h3>
                <a class="inline-block bg-white text-black px-12 py-5 font-headline font-bold uppercase tracking-widest text-sm hover:bg-stone-200 transition-colors" href="https://wa.me/573008299673">
                    Cotizar ahora
                </a>
            </div>
        </section>
    </main>
</Layout>
