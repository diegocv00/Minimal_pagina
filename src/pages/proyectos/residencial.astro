---
import Layout from '../../layouts/Layout.astro';
import ProjectCarousel from '../../components/ProjectCarousel.astro';

import R1_1 from '../../assets/Residencial1/R1_1.jpeg';
import R1_2 from '../../assets/Residencial1/R1_2.jpeg';
import R1_3 from '../../assets/Residencial1/R1_3.jpeg';
import R1_4 from '../../assets/Residencial1/R1_4.jpeg';
import R1_5 from '../../assets/Residencial1/R1_5.jpeg';
import R1_6 from '../../assets/Residencial1/R1_6.jpeg';
import R1_7 from '../../assets/Residencial1/R1_7.jpeg';
import R1_8 from '../../assets/Residencial1/R1_8.jpeg';

import R2_1 from '../../assets/Residencial2/R2_1.jpeg';
import R2_2 from '../../assets/Residencial2/R2_2.jpeg';
import R2_3 from '../../assets/Residencial2/R2_3.jpeg';
import R2_4 from '../../assets/Residencial2/R2_4.jpeg';
import R2_5 from '../../assets/Residencial2/R2_5.jpeg';
import R2_6 from '../../assets/Residencial2/R2_6.jpeg';
import R2_7 from '../../assets/Residencial2/R2_7.jpeg';
import R2_8 from '../../assets/Residencial2/R2_8.jpeg';
import R2_9 from '../../assets/Residencial2/R2_9.jpeg';
import R2_10 from '../../assets/Residencial2/R2_10.jpeg';
import R2_11 from '../../assets/Residencial2/R2_11.jpeg';
 
import R3_1 from '../../assets/Residencial3/R3_1.jpeg';
import R3_2 from '../../assets/Residencial3/R3_2.jpeg';
import R3_3 from '../../assets/Residencial3/R3_3.jpeg';
import R3_4 from '../../assets/Residencial3/R3_4.jpeg';
import R3_5 from '../../assets/Residencial3/R3_5.jpeg';

interface Project {
    id: string;
    title: string;
    location: string;
    description: string;
    images: string[];
    span: string;
}

const projects: Project[] = [
    {
        id: 'residencial-1',
        title: 'RESIDENCIAL 1',
        location: '', 
        description: 'Remodelación de un apartamento enfocada en la optimización del espacio y materialidad pura.',
        images: [
            R1_1.src,
            R1_2.src,
            R1_3.src,
            R1_4.src,
            R1_5.src,
            R1_6.src,
            R1_7.src,
            R1_8.src
        ],
        span: 'md:col-span-10 md:col-start-2'
    },

    {
        id: 'residencial-2',
        title: 'RESIDENCIAL 2',
        location: '', 
        description: 'Vivienda unifamiliar con énfasis en la conexión interior-exterior y materialidad contemporánea.',
        images: [
            R2_1.src,
            R2_2.src,
            R2_3.src,
            R2_4.src,
            R2_5.src,
            R2_6.src,
            R2_7.src,
            R2_8.src,
            R2_9.src,
            R2_10.src
        ],
        span: 'md:col-span-12'
    },
    {
        id: 'residencial-3',
        title: 'RESIDENCIAL 3',
        location: '', 
        description: 'Vivienda unifamiliar enfocada en la armonía geométrica y materialidad contemporánea.',
        images: [
            R3_1.src,
            R3_2.src,
            R3_3.src,
            R3_4.src,
            R3_5.src
        ],
        span: 'md:col-span-12'
    }
];
---

<Layout title="Minimal arquitectura | Residencial">
    <main class="pt-32 pb-24">
        <!-- Section Header -->
        <header class="px-8 mb-12">
            <div class="max-w-[1920px] mx-auto flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div>
                    <span class="font-label text-[1rem] uppercase tracking-[0.2em] text-outline mb-4 block"> Sector</span>
                    <h1 class="font-headline text-[2.5rem] sm:text-[3rem] md:text-[3.5rem] leading-none font-extrabold tracking-tighter uppercase text-stone-900">RESIDENCIAL</h1>
                </div>
                <div class="max-w-md">
                    <p class="font-body text-lg text-on-surface-variant leading-relaxed font-light">
                        Una curación de viviendas monolíticas, explorando la intersección entre masa pesada y luz etérea. La arquitectura como contenedor silencioso de vida.
                    </p>
                </div>
            </div>
        </header>

        <!-- Projects: Full-Width Sections -->
        <div>
            {projects.map((project) => (
                <section class="mb-20 md:mb-32 overflow-hidden">
                    <!-- Global Image Block -->
                    <div class="w-full relative bg-stone-100 aspect-video md:aspect-21/9">
                        <ProjectCarousel images={project.images} id={project.id} />
                    </div>
                    
                    <!-- Global Info Block -->
                    <div class="w-full mt-6 md:mt-8 px-8">
                        <div class="grid grid-cols-1 md:grid-cols-12">
                            <div class="md:col-span-12">
                                <h2 class="font-headline text-3xl md:text-4xl font-extrabold uppercase tracking-tighter mb-4 leading-none">
                                    {project.title}
                                </h2>
                                <p class="font-body text-[0.95rem] md:text-lg text-on-surface-variant leading-relaxed opacity-80 max-w-none">
                                    {project.description}
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
            ))}
        </div>



        <!-- CTA Section: Minimalist Intervention -->
        <section class="mt-48 px-8 py-32 bg-stone-950 text-white flex items-center justify-center text-center">
            <div class="max-w-2xl">
                <h3 class="font-headline text-4xl font-extrabold uppercase tracking-tighter mb-8 italic">Empieza tu propio proyecto minimalista</h3>
                <a class="inline-block bg-white text-black px-12 py-5 font-headline font-bold uppercase tracking-widest text-sm hover:bg-stone-200 transition-colors" href="https://wa.me/573008299673">
                    Consultar Ahora
                </a>
            </div>
        </section>
    </main>
</Layout>
