---
import Layout from '../../layouts/Layout.astro';
import ProjectList from '../../components/ProjectList.astro';
import ProjectCTA from '../../components/ProjectCTA.astro';

const mapImages = (modules: Record<string, any>) =>
    Object.values(modules)
        .map((m: any) => m.default?.src ?? '').filter(Boolean)
        .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));

const projects = [
    { id: 'aptocc', title: 'APARTAMENTO CC', images: mapImages(import.meta.glob('../../assets/AptoCC/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'aptocv', title: 'APARTAMENTO CV301', images: mapImages(import.meta.glob('../../assets/AptoCV/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'apto602', title: 'APARTAMENTO 602', images: mapImages(import.meta.glob('../../assets/Apto602/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'aptolr', title: 'APARTAMENTO LR', images: mapImages(import.meta.glob('../../assets/AptoLR/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'casaMadrigal', title: 'CASA MADRIGAL', images: mapImages(import.meta.glob('../../assets/CasaMadrigal/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'casaMC', title: 'CASA MC', images: mapImages(import.meta.glob('../../assets/CasaMC/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'aptoK604', title: 'APARTAMENTO K604', images: mapImages(import.meta.glob('../../assets/AptoK604/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'casaM8', title: 'CASA MONTAÑA 8', images: mapImages(import.meta.glob('../../assets/CasaM8/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'casaMS', title: 'CASA MS', images: mapImages(import.meta.glob('../../assets/CasaMS/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'casaRefugio', title: 'CASA REFUGIO', images: mapImages(import.meta.glob('../../assets/CasaRefugio/*.{jpeg,jpg,png}', { eager: true })) },
    { id: 'casaDosAguas', title: 'CASA DOS AGUAS', images: mapImages(import.meta.glob('../../assets/CasaDosAguas/*.{jpeg,jpg,png}', { eager: true })) },
];
---

<Layout title="Minimal arquitectura | Residencial">
    <main class="pt-32 pb-24">
        <header class="px-8 mb-12">
            <div class="max-w-[1920px] mx-auto flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div>
                    <span class="font-label text-[1rem] uppercase tracking-[0.2em] text-outline mb-4 block"> Sector</span>
                    <h1 class="font-headline text-[2.5rem] sm:text-[3rem] md:text-[3.5rem] leading-none font-extrabold tracking-tighter uppercase text-stone-900">RESIDENCIAL</h1>
                </div>
            </div>
        </header>

        <ProjectList projects={projects} />
        <ProjectCTA />
    </main>
</Layout>
