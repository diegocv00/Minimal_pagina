---
import Layout from '../../layouts/Layout.astro';
import ProjectList from '../../components/ProjectList.astro';
import ProjectCTA from '../../components/ProjectCTA.astro';

const ffImages = Object.values(import.meta.glob('../../assets/FiscaliaFloridablanca/*.{jpeg,jpg,png}', { eager: true }))
    .map((m: any) => m.default?.src ?? '').filter(Boolean)
    .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
const camvscImages = Object.values(import.meta.glob('../../assets/CAMSanVicenteDeChucuri/*.{jpeg,jpg,png}', { eager: true }))
    .map((m: any) => m.default?.src ?? '').filter(Boolean)
    .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
const mcprImages = Object.values(import.meta.glob('../../assets/MegaColegioPuertoRico/*.{jpeg,jpg,png}', { eager: true }))
    .map((m: any) => m.default?.src ?? '').filter(Boolean)
    .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
const pyImages = Object.values(import.meta.glob('../../assets/ParqueYondo/*.{jpeg,jpg,png}', { eager: true }))
    .map((m: any) => m.default?.src ?? '').filter(Boolean)
    .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));

const projects = [
    { id: 'FF', title: 'FISCALIA FLORIDABLANCA', images: ffImages },
    { id: 'CAMVSC', title: 'CAM SAN VICENTE CHUCURI', images: camvscImages },
    { id: 'MCPR', title: 'MEGACOLEGIO PUERTO RICO', images: mcprImages },
    { id: 'ParqueYondo', title: 'PARQUE YONDO', images: pyImages },
];
---

<Layout title="Minimal arquitectura | Institucional">
    <main class="pt-32 pb-24">
        <header class="px-8 mb-24 max-w-[1920px] mx-auto">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div class="max-w-4xl">
                    <p class="font-label text-[1rem] mb-4 text-outline uppercase tracking-widest"> Sector</p>
                    <h1 class="font-headline text-4xl sm:text-[3rem] md:text-[3.5rem] leading-none font-extrabold tracking-tighter uppercase">INSTITUCIONAL</h1>
                </div>
            </div>
        </header>

        <ProjectList projects={projects} />
        <ProjectCTA />
    </main>
</Layout>
