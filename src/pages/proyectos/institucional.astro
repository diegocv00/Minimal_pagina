---

<Layout title="Minimal arquitectura | Institucional">
    <main class="pt-32 pb-24">
        <!-- Hero Header -->
        <header class="px-8 mb-24 max-w-[1920px] mx-auto">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div class="max-w-4xl">
                    <p class="font-label text-[1rem] mb-4 text-outline uppercase tracking-widest"> Sector</p>
                    <h1 class="font-headline text-[3.5rem] leading-[1.1] font-extrabold tracking-tighter uppercase">INSTITUCIONAL</h1>
                </div>
                <div class="max-w-sm">
                    <p class="font-body text-lg text-on-surface-variant leading-relaxed">
                        Una curación de espacios públicos donde el concreto se encuentra con la comunidad. Nuestro trabajo institucional explora el brutalismo a través de la lente de la utilidad cívica moderna.
                    </p>
                </div>
            </div>
        </header>

        <!-- Projects: Full-Width Sections -->
        <div>
            {projects.map((project) => (
                <section class="mb-20 md:mb-32 overflow-hidden">
                    <!-- Global Image Block -->
                    <div class="w-full relative bg-stone-100 aspect-video md:aspect-21/9">
                        <ProjectCarousel images={project.images} id={project.id} />
                    </div>
                    
                    <!-- Global Info Block -->
                    <div class="w-full mt-6 md:mt-8 px-8">
                        <div class="grid grid-cols-1 md:grid-cols-12">
                            <div class="md:col-span-12">
                                <h2 class="font-headline text-3xl md:text-4xl font-extrabold uppercase tracking-tighter mb-4 leading-none">
                                    {project.title}
                                </h2>
                                <p class="font-body text-[0.95rem] md:text-lg text-on-surface-variant leading-relaxed opacity-80 max-w-none">
                                    {project.description}
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
            ))}
        </div>



        <!-- Call to Action -->
        <section class="py-40 px-8 text-center max-w-4xl mx-auto">
            <h4 class="font-headline text-[3.5rem] leading-[1.1] font-bold uppercase mb-12 tracking-tight">Construye Firmes <br/>Cimientos para el Futuro.</h4>
            <div class="flex flex-col md:flex-row justify-center gap-6">
                <a class="px-10 py-5 bg-primary text-on-primary uppercase font-label text-[0.75rem] font-bold tracking-[0.2em] transition-all duration-300 hover:scale-105" href="https://wa.me/573008299673">Iniciar un Proyecto</a>
                <a class="px-10 py-5 border border-primary text-primary uppercase font-label text-[0.75rem] font-bold tracking-[0.2em] transition-all duration-300 hover:bg-primary hover:text-on-primary" href="/proyectos">Ver Portafolio</a>
            </div>
        </section>
    </main>
</Layout>
