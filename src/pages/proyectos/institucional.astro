---
import Layout from '../../layouts/Layout.astro';
import ProjectCarousel from '../../components/ProjectCarousel.astro';
import fondoBanner from '../../assets/fondoBanner.png';

import FF1 from '../../assets/FiscaliaFloridablanca/FF1.jpg';
import FF2 from '../../assets/FiscaliaFloridablanca/FF2.jpg';
import FF3 from '../../assets/FiscaliaFloridablanca/FF3.jpg';
import FF4 from '../../assets/FiscaliaFloridablanca/FF4.jpg';
import FF5 from '../../assets/FiscaliaFloridablanca/FF5.jpg';

import CAMSVC1 from '../../assets/CAMSanVicenteDeChucuri/CAMSVC1.png';
import CAMSVC2 from '../../assets/CAMSanVicenteDeChucuri/CAMSVC2.png';
import CAMSVC3 from '../../assets/CAMSanVicenteDeChucuri/CAMSVC3.png';
import CAMSVC4 from '../../assets/CAMSanVicenteDeChucuri/CAMSVC4.png';
import CAMSVC5 from '../../assets/CAMSanVicenteDeChucuri/CAMSVC5.png';
import CAMSVC6 from '../../assets/CAMSanVicenteDeChucuri/CAMSVC6.png';
import CAMSVC7 from '../../assets/CAMSanVicenteDeChucuri/CAMSVC7.png';

import MCPR1 from '../../assets/MegaColegioPuertoRico/MCPR1.png';
import MCPR2 from '../../assets/MegaColegioPuertoRico/MCPR2.png';
import MCPR3 from '../../assets/MegaColegioPuertoRico/MCPR3.png';
import MCPR4 from '../../assets/MegaColegioPuertoRico/MCPR4.png';
import MCPR5 from '../../assets/MegaColegioPuertoRico/MCPR5.png';
import MCPR6 from '../../assets/MegaColegioPuertoRico/MCPR6.png';
import MCPR7 from '../../assets/MegaColegioPuertoRico/MCPR7.png';

import PY1 from '../../assets/ParqueYondo/PY1.png';
import PY2 from '../../assets/ParqueYondo/PY2.png';
import PY3 from '../../assets/ParqueYondo/PY3.png';
import PY4 from '../../assets/ParqueYondo/PY4.png';
import PY5 from '../../assets/ParqueYondo/PY5.png';
import PY6 from '../../assets/ParqueYondo/PY6.png';
import PY7 from '../../assets/ParqueYondo/PY7.png';


interface Project {
    id: string;
    title: string;
    description: string;
    images: string[];
    span: string;
}

const projects: Project[] = [
    {
        id: 'FF',
        title: 'FISCALIA FLORIDABLANCA',
        description: '',
        images: [
            FF1.src,
            FF2.src,
            FF3.src,
            FF4.src,
            FF5.src
        ],
        span: 'md:col-span-10 md:col-start-2'
    },
    {
        id: 'CAMVSC',
        title: 'CAM SAN VICENTE CHUCURI',
        description: '',
        images: [
            CAMSVC1.src,
            CAMSVC2.src,
            CAMSVC3.src,
            CAMSVC4.src,
            CAMSVC5.src,
            CAMSVC6.src,
            CAMSVC7.src
        ],
        span: 'md:col-span-6 lg:col-span-4'
    },
    {
        id: 'MCPR',
        title: 'MEGACOLEGIO PUERTO RICO',
        description: '',
        images: [
            MCPR1.src,
            MCPR2.src,
            MCPR3.src,
            MCPR4.src,  
            MCPR5.src,
            MCPR6.src,
            MCPR7.src
        ],
        span: 'md:col-span-6 lg:col-span-8'
    },
        {
        id: 'ParqueYondo',
        title: 'PARQUE YONDO',
        description: '',
        images: [
            PY1.src,
            PY2.src,
            PY3.src,
            PY4.src,
            PY5.src,
            PY6.src,
            PY7.src
        ],
        span: 'md:col-span-6 lg:col-span-4'
    },

];
---

<Layout title="Minimal arquitectura | Institucional">
    <main class="pt-32 pb-24">
        <!-- Hero Header -->
        <header class="px-8 mb-24 max-w-[1920px] mx-auto">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div class="max-w-4xl">
                    <p class="font-label text-[1rem] mb-4 text-outline uppercase tracking-widest"> Sector</p>
                    <h1 class="font-headline text-4xl sm:text-[3rem] md:text-[3.5rem] leading-none font-extrabold tracking-tighter uppercase">INSTITUCIONAL</h1>
                </div>

            </div>
        </header>

        <!-- Projects: Full-Width Sections -->
        <div>
            {projects.map((project) => (
                <section class="mb-20 md:mb-32 overflow-hidden">
                    <!-- Global Image Block -->
                    <div class="w-full relative bg-stone-100 aspect-video md:aspect-21/9">
                        <ProjectCarousel images={project.images} id={project.id} />
                    </div>
                    
                    <!-- Global Info Block -->
                    <div class="w-full mt-6 md:mt-8 px-8">
                        <div class="grid grid-cols-1 md:grid-cols-12">
                            <div class="md:col-span-12">
                                <h2 class="font-headline text-3xl md:text-4xl font-extrabold uppercase tracking-tighter mb-4 leading-none">
                                    {project.title}
                                </h2>
                                <p class="font-body text-[0.95rem] md:text-lg text-on-surface-variant leading-relaxed opacity-80 max-w-none">
                                    {project.description}
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
            ))}
        </div>



        <!-- Call to Action -->
        <section class="relative mt-48 px-8 py-32 bg-stone-950 text-white flex items-center justify-center text-center bg-cover bg-center" style={`background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(${fondoBanner.src});`}>
            <div class="relative z-10 max-w-2xl">
                <h3 class="font-headline text-4xl font-extrabold uppercase tracking-tighter mb-8 italic">Empieza tu sueño</h3>
                <a class="inline-block bg-white text-black px-12 py-5 font-headline font-bold uppercase tracking-widest text-sm hover:bg-stone-200 transition-colors" href="https://wa.me/573008299673">
                    Cotizar ahora
                </a>
            </div>
        </section>
    </main>
</Layout>
