---

<Layout title="Minimal arquitectura | Comercial">
    <main class="pt-32 pb-24">
        <!-- Header Section -->
        <header class="px-8 mb-24 max-w-[1920px] mx-auto">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div class="max-w-2xl">
                    <span class="font-label text-[1rem] uppercase tracking-[0.2em] text-outline mb-4 block"> Sector</span>
                    <h1 class="font-headline text-4xl sm:text-[3rem] md:text-[3.5rem] lg:text-7xl font-extrabold tracking-tighter leading-none mb-6">COMERCIAL</h1>
                </div>
                <div class="md:w-1/3">
                    <p class="font-body text-lg text-on-surface-variant leading-relaxed font-light">
                        Una selección curada de intervenciones urbanas de alta densidad, atmósferas comerciales y monolitos de espacio de trabajo cristalinos.
                    </p>
                </div>
            </div>
        </header>

        <!-- Projects: Full-Width Sections -->
        <div>
            {projects.map((project) => (
                <section class="mb-20 md:mb-32 overflow-hidden">
                    <!-- Global Image Block -->
                    <div class="w-full relative bg-stone-100 aspect-video md:aspect-21/9">
                        <ProjectCarousel images={project.images} id={project.id} />
                    </div>
                    
                    <!-- Global Info Block -->
                    <div class="w-full mt-6 md:mt-8 px-8">
                        <div class="grid grid-cols-1 md:grid-cols-12">
                            <div class="md:col-span-12">
                                <h2 class="font-headline text-3xl md:text-4xl font-extrabold uppercase tracking-tighter mb-4 leading-none">
                                    {project.title}
                                </h2>
                                <p class="font-body text-[0.95rem] md:text-lg text-on-surface-variant leading-relaxed opacity-80 max-w-none">
                                    {project.description}
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
            ))}
        </div>



        <!-- CTA Section -->
        <section class="relative mt-48 px-8 py-32 bg-stone-950 text-white flex items-center justify-center text-center bg-cover bg-center" style={`background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(${fondoBanner.src});`}>
            <div class="relative z-10 max-w-2xl">
                <h3 class="font-headline text-4xl font-extrabold uppercase tracking-tighter mb-8 italic">Empieza tu sueño</h3>
                <a class="inline-block bg-white text-black px-12 py-5 font-headline font-bold uppercase tracking-widest text-sm hover:bg-stone-200 transition-colors" href="https://wa.me/573008299673">
                    Cotizar ahora
                </a>
            </div>
        </section>
    </main>
</Layout>
