---
import Layout from '../../layouts/Layout.astro';
import ProjectList from '../../components/ProjectList.astro';
import ProjectCTA from '../../components/ProjectCTA.astro';

const OFLCImages = Object.values(import.meta.glob('../../assets/OficinasLaColombiana/*.{jpeg,jpg,png}', { eager: true }))
    .map((m: any) => m.default?.src ?? '').filter(Boolean)
    .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
const essenceRImages = Object.values(import.meta.glob('../../assets/Essence_R/*.{jpeg,jpg,png}', { eager: true }))
    .map((m: any) => m.default?.src ?? '').filter(Boolean)
    .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
const aptoABNBImages = Object.values(import.meta.glob('../../assets/AptoAirBNB/*.{jpeg,jpg,png}', { eager: true }))
    .map((m: any) => m.default?.src ?? '').filter(Boolean)
    .sort((a: string, b: string) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));

const projects = [
    { id: 'OFLC', title: 'OFICINAS LA COLOMBIANA', images: OFLCImages },
    { id: 'essence-r', title: 'ESSENCE R', images: essenceRImages },
    { id: 'aptoABNB', title: 'APARTAMENTO AIRBNB', images: aptoABNBImages },
];
---

<Layout title="Minimal arquitectura | Comercial">
    <main class="pt-32 pb-24">
        <header class="px-8 mb-24 max-w-[1920px] mx-auto">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
                <div class="max-w-2xl">
                    <span class="font-label text-[1rem] uppercase tracking-[0.2em] text-outline mb-4 block"> Sector</span>
                    <h1 class="font-headline text-4xl sm:text-[3rem] md:text-[3.5rem] lg:text-7xl font-extrabold tracking-tighter leading-none mb-6">COMERCIAL</h1>
                </div>
            </div>
        </header>

        <ProjectList projects={projects} />
        <ProjectCTA />
    </main>
</Layout>
