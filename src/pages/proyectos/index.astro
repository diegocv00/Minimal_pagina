---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Minimal Arquitectura | Proyectos">
    <main class="pt-32 pb-24">
        <!-- Header Section -->
        <header class="px-8 mb-24 max-w-[1920px] mx-auto">
            <h1
                class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-none mb-6"
            >
                NUESTROS PROYECTOS
            </h1>
            <p
                class="font-body text-lg text-on-surface-variant leading-relaxed font-light max-w-2xl"
            >
                Explora nuestro catálogo completo dividido en zonas de
                intervención. Cada estructura refleja nuestra filosofía de
                materialidad honesta e integración contextual adaptada al
                propósito de sus habitantes.
            </p>
        </header>

        <!-- Project Categories -->
        <section
            class="px-8 max-w-[1920px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-12"
        >
            <a href="/proyectos/comercial" class="group block">
                <div
                    class="aspect-[4/5] overflow-hidden bg-surface-container-low mb-6"
                >
                    <img
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCys2C236QTQnFrau5CINKZFL578Hm5-QxPExPDtSpG7QmnCu6ws-hJdDZO-DCWmfUZRFzZwcwtDwd01dWVFkgQnznPtkSfEamZc-QqOiTycW1keOlhD7cuFk_IjYmaBXXJsdNq-MUjm6VaUMqTROcJw47hSVrDDT5p-9yQHSRcsid6QpK2ocFmIFqcGBc2kQfSMaqgnbnRoFXUPGCvRXFK8rcGhKPRviTuivXc9bkZ935cGIWcGDeG2NNpxKnCL2PLfRQaDVrnTbYS"
                        alt="Proyectos Comerciales"
                        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    />
                </div>
                <h2
                    class="font-headline text-2xl font-bold uppercase tracking-tight group-hover:text-primary/70 transition-colors"
                >
                    Comercial
                </h2>
                <p class="font-body text-sm text-on-surface-variant mt-2">
                    Torres de oficinas, boutiques retail y plazas empresariales.
                </p>
            </a>

            <a href="/proyectos/institucional" class="group block">
                <div
                    class="aspect-[4/5] overflow-hidden bg-surface-container-low mb-6"
                >
                    <img
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBEijYhtNeNQzeV-Dml6bGm_LulqViqceIS69AWqsjnV5OD2Dw_ifXmy-rGk7WMolB05XOSMHTZymou929_OZ5NEwc_gH1fzodia2t45Oe18m-g8WoCC_A_3d0abdtzgAmwepbHf858j1qQBXVF-ZsNMhoqXyW-yvHqGi0zxeCcvgfzQg3ZKoQNyszYONFg3r_5w06yskRZ3l0U2jogXfItS_ohE5TpmCWB7ZluN1iZVV0hI9s_LztY_rJZB5lWlZz7HdEzsM-Us5IM"
                        alt="Proyectos Institucionales"
                        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    />
                </div>
                <h2
                    class="font-headline text-2xl font-bold uppercase tracking-tight group-hover:text-primary/70 transition-colors"
                >
                    Institucional
                </h2>
                <p class="font-body text-sm text-on-surface-variant mt-2">
                    Museos, escuelas y atrios cívicos fundados en la durabilidad
                    comunitaria.
                </p>
            </a>

            <a href="/proyectos/residencial" class="group block">
                <div
                    class="aspect-[4/5] overflow-hidden bg-surface-container-low mb-6"
                >
                    <img
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAQLsEWkyyCP5ZTKi5RFo1XTYCetPT6iyqEAy4uKl_OkZGt2II8_Dmjxzr5pUnOn79M-T5bAOEYAIbd-MGrEjFYZUsHvzR9LO-SRYDeXADa3w8EDBz1VnX3YPsioMfDM9uK0fFiNDgMZ9yOiE-jpJIGUX7MVwzCjDiBXb1UqpRNlF6s-1vvTh5hkrBo6KxcFc7Dd76YHgzEnajK9BbZzotKgN1_dB3J9v29_5XJEC8NC_OxEUYqE27o1hNm4wbcBqpkmEzqSnI-6IZK"
                        alt="Proyectos Residenciales"
                        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    />
                </div>
                <h2
                    class="font-headline text-2xl font-bold uppercase tracking-tight group-hover:text-primary/70 transition-colors"
                >
                    Residencial
                </h2>
                <p class="font-body text-sm text-on-surface-variant mt-2">
                    Viviendas monolíticas y refugios de intimidad estructural.
                </p>
            </a>
        </section>
    </main>
</Layout>
