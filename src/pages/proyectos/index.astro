---
import Layout from "../../layouts/Layout.astro";
import FF1 from "../../assets/FiscaliaFloridablanca/FF1.jpg";
import AptoCV_1 from "../../assets/AptoCV/AptoCV_1.jpeg";
import ER4 from "../../assets/Essence_R/ER4.jpeg";
---

<Layout title="Minimal arquitectura | Proyectos">
    <main class="pt-32 pb-24">
        <header class="px-8 mb-24 max-w-[1920px] mx-auto">
            <h1
                class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-none mb-6"
            >
                NUESTROS PROYECTOS
            </h1>
            <p
                class="font-body text-lg text-on-surface-variant leading-relaxed font-light max-w-2xl"
            >
                Explora nuestro catalogo completo dividido en zonas de
                intervencion.
            </p>
        </header>

        <section
            class="px-8 max-w-[1920px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-12"
        >
            <a href="/proyectos/residencial" class="group block">
                <div
                    class="aspect-4/5 overflow-hidden bg-surface-container-low mb-6"
                >
                    <img
                        src={AptoCV_1.src}
                        alt="Proyectos Residenciales"
                        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    />
                </div>
                <h2
                    class="font-headline text-2xl font-bold uppercase tracking-tight group-hover:text-primary/70 transition-colors"
                >
                    Residencial
                </h2>

            </a>

            <a href="/proyectos/comercial" class="group block">
                <div
                    class="aspect-4/5 overflow-hidden bg-surface-container-low mb-6"
                >
                    <img
                        src={ER4.src}
                        alt="Proyectos Comerciales"
                        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    />
                </div>
                <h2
                    class="font-headline text-2xl font-bold uppercase tracking-tight group-hover:text-primary/70 transition-colors"
                >
                    Comercial
                </h2>
            </a>

            <a href="/proyectos/institucional" class="group block">
                <div
                    class="aspect-4/5 overflow-hidden bg-surface-container-low mb-6"
                >
                    <img
                        src={FF1.src}
                        alt="Proyectos Institucionales"
                        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    />
                </div>
                <h2
                    class="font-headline text-2xl font-bold uppercase tracking-tight group-hover:text-primary/70 transition-colors"
                >
                    Institucional
                </h2>
            </a>
        </section>
    </main>
</Layout>
