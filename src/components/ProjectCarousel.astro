---
interface Props {
    images: string[];
    id: string;
    columns?: number;
}

const { images, id, columns = 3 } = Astro.props;
const displayColumns = columns === 1 ? 'md:w-full' : 'md:w-1/3';
const bufferCount = columns === 1 ? 1 : 3;
---

<div
    class="relative group/carousel w-full h-full overflow-hidden bg-stone-100"
    id={`carousel-${id}`}
>
    <!-- Main Carousel Container -->
    <div
        class="flex w-full h-full overflow-x-auto scroll-smooth snap-x snap-mandatory no-scrollbar"
        id={`scroll-${id}`}
    >
        {
            images.map((img, index) => (
                <div class={`flex-none w-full ${displayColumns} h-full snap-start relative`}>
                    <img
                        src={img}
                        alt={`Project view ${index + 1}`}
                        class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
                    />
                </div>
            ))
        }

    </div>

    <!-- Navigation Arrows -->
    <button
        class="absolute left-8 top-1/2 -translate-y-1/2 z-20 p-2 text-white/50 hover:text-white transition-colors opacity-0 group-hover/carousel:opacity-100 hidden md:block"
        id={`prev-${id}`}
        aria-label="Previous image"
    >
        <span class="material-symbols-outlined text-6xl font-light"
            >chevron_left</span
        >
    </button>
    <button
        class="absolute right-8 top-1/2 -translate-y-1/2 z-20 p-2 text-white/50 hover:text-white transition-colors opacity-0 group-hover/carousel:opacity-100 hidden md:block"
        id={`next-${id}`}
        aria-label="Next image"
    >
        <span class="material-symbols-outlined text-6xl font-light"
            >chevron_right</span
        >
    </button>

    <!-- Progress Line -->
    <div class="absolute bottom-0 left-0 w-full h-0.5 bg-white/10 z-20">
        <div 
            class="h-full bg-white/60 transition-all duration-300" 
            id={`progress-${id}`}
            style="width: 0%"
        ></div>
    </div>
</div>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script is:inline define:vars={{ id, count: images.length }}>
    const scroller = document.getElementById(`scroll-${id}`);
    const prevBtn = document.getElementById(`prev-${id}`);
    const nextBtn = document.getElementById(`next-${id}`);
    const progressBar = document.getElementById(`progress-${id}`);

    if (scroller && prevBtn && nextBtn) {
        const getStepSize = () => {
            const firstItem = scroller.querySelector('div');
            return firstItem ? firstItem.offsetWidth : scroller.offsetWidth;
        };

        prevBtn.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (scroller.scrollLeft <= 10) {
                scroller.scrollTo({ left: scroller.scrollWidth, behavior: 'smooth' });
            } else {
                scroller.scrollLeft -= getStepSize();
            }
            resetAutoPlay();
        });

        nextBtn.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            const isAtEnd = scroller.scrollLeft + scroller.offsetWidth >= scroller.scrollWidth - 10;
            if (isAtEnd) {
                scroller.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
                scroller.scrollLeft += getStepSize();
            }
            resetAutoPlay();
        });

        let autoPlayInterval = setInterval(() => {
            const isAtEnd = scroller.scrollLeft + scroller.offsetWidth >= scroller.scrollWidth - 10;
            if (isAtEnd) {
                scroller.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
                scroller.scrollLeft += getStepSize();
            }
        }, 3000);

        function resetAutoPlay() {
            clearInterval(autoPlayInterval);
            autoPlayInterval = setInterval(() => {
                const isAtEnd = scroller.scrollLeft + scroller.offsetWidth >= scroller.scrollWidth - 10;
                if (isAtEnd) {
                    scroller.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    scroller.scrollLeft += getStepSize();
                }
            }, 3000);
        }

        scroller.addEventListener("scroll", () => {
            const maxScroll = scroller.scrollWidth - scroller.offsetWidth;
            const progress = (scroller.scrollLeft / maxScroll) * 100;
            if (progressBar) {
                progressBar.style.width = `${Math.min(100, Math.max(0, progress))}%`;
            }
        });
    }
</script>
