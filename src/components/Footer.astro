---
import logo from "../assets/logo_1.png";
import {
    INSTAGRAM_LINK,
    SITE_NAME,
    WHATSAPP_DISPLAY,
    WHATSAPP_LINK,
} from "../consts/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-outline-variant/50 bg-surface-container-low">
    <div class="site-container py-12 sm:py-16">
        <div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-md">
                <img
                    src={logo.src}
                    alt={SITE_NAME}
                    class="h-14 w-auto sm:h-16"
                />
                <p class="mt-5 text-sm leading-relaxed text-on-surface/70">
                    Arquitectura interior y residencial con una propuesta limpia,
                    atemporal y pensada para responder bien en cualquier
                    pantalla.
                </p>
            </div>

            <div class="grid gap-8 sm:grid-cols-2 lg:min-w-[32rem]">
                <div>
                    <p class="font-label text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-on-surface/50">
                        Navegacion
                    </p>
                    <div class="mt-4 flex flex-col gap-3">
                        <a class="footer-link" href="/">Inicio</a>
                        <a class="footer-link" href="/proyectos">Proyectos</a>
                        <a class="footer-link" href="/nosotros">Nosotros</a>
                    </div>
                </div>

                <div>
                    <p class="font-label text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-on-surface/50">
                        Contacto
                    </p>
                    <div class="mt-4 flex flex-col gap-4">
                        <a
                            class="inline-flex items-center gap-3 text-on-surface transition-colors duration-300 hover:text-primary"
                            href={WHATSAPP_LINK}
                            aria-label={`WhatsApp ${WHATSAPP_DISPLAY}`}
                        >
                            <span class="inline-flex h-11 w-11 items-center justify-center border border-outline-variant bg-surface-container-lowest">
                                <svg
                                    class="h-5 w-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                    xmlns="http://www.w3.org/2000/svg"
                                >
                                    <path
                                        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                                    ></path>
                                </svg>
                            </span>
                            <span class="flex flex-col gap-1">
                                <span class="font-label text-[0.68rem] uppercase tracking-[0.24em] text-on-surface/50">
                                    WhatsApp
                                </span>
                                <span class="text-base font-medium">
                                    {WHATSAPP_DISPLAY}
                                </span>
                            </span>
                        </a>

                        <a
                            class="footer-link inline-flex items-center gap-2"
                            href={INSTAGRAM_LINK}
                        >
                            Instagram
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-10 border-t border-outline-variant/40 pt-5">
            <p class="text-sm text-on-surface/55">
                {SITE_NAME} &copy; {year}
            </p>
        </div>
    </div>
</footer>
